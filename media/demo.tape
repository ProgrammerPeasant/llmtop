# VHS tape for the llmtop demo GIF.
# See README.md "Recording the demo GIF" for full setup. Windows uses ffmpeg
# gdigrab instead — vhs needs ttyd, which has no native Windows build.

Output media/demo.gif

Set FontSize 14
Set Width 1100
Set Height 480
Set Theme "Catppuccin Mocha"
Set Padding 12
Set TypingSpeed 50ms

Type "llmtop"
Enter
Sleep 18s
Type "q"
